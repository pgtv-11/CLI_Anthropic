{
  "name": "avenue-compliance-platform",
  "version": "0.0.1",
  "private": true,
  "description": "Avenue Securities LLC — Internal regulatory compliance platform",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r --parallel build",
    "test": "pnpm -r --parallel test",
    "lint": "pnpm -r --parallel lint",
    "typecheck": "pnpm -r --parallel typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.7.5"
  }
}
